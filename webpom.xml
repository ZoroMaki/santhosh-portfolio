        <!-- ═══════════════════════════════════════════════════
             COMMONS
             ═══════════════════════════════════════════════════ -->
        <dependency>
            <groupId>commons-beanutils</groupId>
            <artifactId>commons-beanutils</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-collections</groupId>
            <artifactId>commons-collections</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-collections4</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-compress</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-digester</groupId>
            <artifactId>commons-digester</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-discovery</groupId>
            <artifactId>commons-discovery</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-fileupload</groupId>
            <artifactId>commons-fileupload</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-io</groupId>
            <artifactId>commons-io</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-lang</groupId>
            <artifactId>commons-lang</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-lang3</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-math3</artifactId>
        </dependency>

        <!-- ═══════════════════════════════════════════════════
             POI (Excel)
             ═══════════════════════════════════════════════════ -->
        <dependency>
            <groupId>org.apache.poi</groupId>
            <artifactId>poi</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.poi</groupId>
            <artifactId>poi-ooxml</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.poi</groupId>
            <artifactId>poi-scratchpad</artifactId>
        </dependency>

        <!-- ═══════════════════════════════════════════════════
             JSON
             ═══════════════════════════════════════════════════ -->
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
        </dependency>
        <dependency>
            <groupId>net.sf.json-lib</groupId>
            <artifactId>json-lib</artifactId>
            <classifier>jdk15</classifier>
        </dependency>

        <!-- ═══════════════════════════════════════════════════
             BYTE MANIPULATION (Hibernate runtime deps)
             ═══════════════════════════════════════════════════ -->
        <dependency>
            <groupId>net.bytebuddy</groupId>
            <artifactId>byte-buddy</artifactId>
        </dependency>
        <dependency>
            <groupId>cglib</groupId>
            <artifactId>cglib</artifactId>
        </dependency>
        <dependency>
            <groupId>org.javassist</groupId>
            <artifactId>javassist</artifactId>
        </dependency>

        <!-- ═══════════════════════════════════════════════════
             HIBERNATE INTERNAL DEPS
             ═══════════════════════════════════════════════════ -->
        <dependency>
            <groupId>dom4j</groupId>
            <artifactId>dom4j</artifactId>
        </dependency>
        <dependency>
            <groupId>antlr</groupId>
            <artifactId>antlr</artifactId>
        </dependency>

        <!-- ═══════════════════════════════════════════════════
             PDF
             ═══════════════════════════════════════════════════ -->
        <dependency>
            <groupId>com.lowagie</groupId>
            <artifactId>itext</artifactId>
        </dependency>

        <!-- ═══════════════════════════════════════════════════
             GROOVY
             ═══════════════════════════════════════════════════ -->
        <dependency>
            <groupId>org.codehaus.groovy</groupId>
            <artifactId>groovy-all</artifactId>
        </dependency>

        <!-- ═══════════════════════════════════════════════════
             CUSTOM / INTERNAL JARS
             Must be installed to local .m2 or Nexus first.
             ═══════════════════════════════════════════════════ -->
        <dependency>
            <groupId>com.isw</groupId>
            <artifactId>iswencryptutility</artifactId>
        </dependency>

    </dependencies>

    <build>
        <finalName>drrevenue-web</finalName>

        <plugins>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>

            <!-- ── WAR packaging ── -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-war-plugin</artifactId>
                <configuration>
                    <!-- Points to your existing WEB-INF/web.xml -->
                    <webXml>${project.basedir}/src/main/webapp/WEB-INF/web.xml</webXml>

                    <!-- web.xml already present — don't fail if it's missing via annotation scanning -->
                    <failOnMissingWebXml>false</failOnMissingWebXml>

                    <!-- Merge React dist/ into the WAR web root at build time -->
                    <webResources>
                        <resource>
                            <!-- Path to Vite dist output from the frontend module -->
                            <directory>
                                ${project.basedir}/../drrevenue-frontend/dist
                            </directory>
                            <!-- Copies directly to WAR root (no prefix folder) -->
                            <targetPath>/</targetPath>
                            <filtering>false</filtering>
                        </resource>
                    </webResources>

                    <!-- Exclude jars WAS 9.x already provides -->
                    <packagingExcludes>
                        WEB-INF/lib/javax.servlet-api-*.jar,
                        WEB-INF/lib/jsp-api-*.jar,
                        WEB-INF/lib/jta-*.jar
                    </packagingExcludes>
                </configuration>
            </plugin>

            <!-- ── Copy React dist BEFORE WAR packages (ensures dist/ is ready) ── -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <executions>
                    <execution>
                        <id>unpack-frontend-dist</id>
                        <phase>generate-resources</phase>
                        <goals>
                            <goal>unpack</goal>
                        </goals>
                        <configuration>
                            <artifactItems>
                                <artifactItem>
                                    <groupId>com.isw.drrevenue</groupId>
                                    <artifactId>drrevenue-frontend</artifactId>
                                    <version>${project.version}</version>
                                    <type>jar</type>
                                    <!-- Extracts dist/ from the frontend jar into target/frontend-dist -->
                                    <outputDirectory>${project.build.directory}/frontend-dist</outputDirectory>
                                    <includes>dist/**</includes>
                                </artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

        </plugins>
    </build>

</project>
